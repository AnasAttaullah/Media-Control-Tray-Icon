<Page
    x:Class="Quick_Media_Controls.Views.Pages.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Quick_Media_Controls.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="GeneralSettingsPage"
    mc:Ignorable="d">

    <StackPanel Margin="30">

        <ui:TextBlock
            Margin="0,0,0,20"
            FontSize="22"
            FontTypography="Subtitle"
            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
            Text="General Settings" />

        <CheckBox Content="Start with Windows" />
        <CheckBox Content="Enable automatic updates" />
        <CheckBox Content="Enable flyout animations" />
        <CheckBox Content="Enable drag mode by default" />

    </StackPanel>
</Page>
